<ResourceDictionary x:Class="ExplorerTabUtility.UI.Themes.TreeViewStyles"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:ExplorerTabUtility.Models"
                    xmlns:behaviors="clr-namespace:ExplorerTabUtility.UI.Behaviors"
                    xmlns:converters="clr-namespace:ExplorerTabUtility.UI.Converters">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ExplorerTabUtility;component/UI/Themes/TextBoxStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    <!--图标样式-->
    <Style x:Key="BookmarkIconStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
        <Setter Property="FontSize" Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!--显示文本样式-->
    <Style x:Key="BookmarkDisplayStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <!--编辑文本样式-->
    <Style x:Key="BookmarkEditStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource CustomTextBoxStyle}">
        <Setter Property="Width" Value="200"/>
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!--保存书签的显示样式-->
    <HierarchicalDataTemplate x:Key="BookmarkSaveDisplayStyle" DataType="{x:Type models:BookmarkTreeViewInfo}" ItemsSource="{Binding Children}">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="Icon" Text="{Binding Icon}" Style="{StaticResource BookmarkIconStyle}"/>
            <TextBlock Text="{Binding Name}" Style="{StaticResource BookmarkDisplayStyle}"
                       Visibility="{Binding IsEditMode,Converter={StaticResource BoolToVisibilityConverter},ConverterParameter={x:Static Visibility.Collapsed}}"/>
            <TextBox Text="{Binding Name}" Tag="文件夹名" Style="{StaticResource BookmarkEditStyle}"
                     behaviors:BookmarkHelper.IsFocused="{Binding IsEditMode}"
                     Visibility="{Binding IsEditMode,Converter={StaticResource BoolToVisibilityConverter},ConverterParameter={x:Static Visibility.Visible}}"
                     LostFocus="BookmarkEdit_LostFocus" KeyDown="BookmarkEdit_KeyDown"/>
        </StackPanel>
        <HierarchicalDataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}" Value="True">
                <Setter TargetName="Icon" Property="Text" Value="{Binding ExpandedIcon}"/>
            </DataTrigger>
        </HierarchicalDataTemplate.Triggers>
    </HierarchicalDataTemplate>

    <!--保存书签的容器样式-->
    <Style x:Key="BookmarkSaveItemContainerStyle" TargetType="{x:Type TreeViewItem}">
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
    </Style>

    <!--保存书签的树形控件样式-->
    <Style x:Key="BookmarkSaveTreeViewStyle" TargetType="TreeView">
        <Setter Property="Height" Value="300"/>
        <Setter Property="Margin" Value="4 0 4 0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ItemTemplate" Value="{StaticResource BookmarkSaveDisplayStyle}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource BookmarkSaveItemContainerStyle}"/>
    </Style>
</ResourceDictionary>