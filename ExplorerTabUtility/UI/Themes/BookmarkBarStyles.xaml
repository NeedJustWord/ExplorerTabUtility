<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:model="clr-namespace:ExplorerTabUtility.Models"
                    xmlns:converters="clr-namespace:ExplorerTabUtility.UI.Converters">

    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    <!--图标样式-->
    <Style x:Key="BookmarkBarIconStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
        <Setter Property="FontSize" Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="4" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!--显示文本样式-->
    <Style x:Key="BookmarkBarDisplayStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4" />
    </Style>

    <!-- 文件夹的右键菜单 -->
    <ContextMenu x:Key="FolderContextMenu">
        <MenuItem Header="重命名"
                  Command="{Binding PlacementTarget.DataContext.MenuClickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                  CommandParameter="{x:Static model:BookmarkBarAction.Rename}"/>
        <MenuItem Header="删除"
                  Command="{Binding PlacementTarget.DataContext.MenuClickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                  CommandParameter="{x:Static model:BookmarkBarAction.Delete}"/>
    </ContextMenu>

    <!-- 书签的右键菜单 -->
    <ContextMenu x:Key="BookmarkContextMenu">
        <MenuItem Header="在当前标签页打开"
                  Command="{Binding PlacementTarget.DataContext.MenuClickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                  CommandParameter="{x:Static model:BookmarkBarAction.OpenInCurrentTab}"/>
        <MenuItem Header="在新标签页打开"
                  Command="{Binding PlacementTarget.DataContext.MenuClickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                  CommandParameter="{x:Static model:BookmarkBarAction.OpenInNewTab}"/>
        <MenuItem Header="在新窗口打开"
                  Command="{Binding PlacementTarget.DataContext.MenuClickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                  CommandParameter="{x:Static model:BookmarkBarAction.OpenInNewWindow}"/>
        <MenuItem Header="编辑"
                  Command="{Binding PlacementTarget.DataContext.MenuClickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                  CommandParameter="{x:Static model:BookmarkBarAction.Edit}"/>
        <MenuItem Header="删除"
                  Command="{Binding PlacementTarget.DataContext.MenuClickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                  CommandParameter="{x:Static model:BookmarkBarAction.Delete}"/>
    </ContextMenu>

    <!--子项容器样式-->
    <HierarchicalDataTemplate x:Key="BookmarkBarSubItemStyle" DataType="{x:Type model:BookmarkBarInfo}" ItemsSource="{Binding Path=Children}">
    </HierarchicalDataTemplate>

    <!--菜单项样式-->
    <Style x:Key="BookmarkBarMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Command" Value="{Binding ClickCommand}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Grid x:Name="PART_Grid" Background="{StaticResource ControlBackgroundBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Icon}" Style="{StaticResource BookmarkBarIconStyle}"
                                   Visibility="{Binding IsVisibility,Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Visible}}" />

                        <TextBlock x:Name="TxtName" Grid.Column="1" Text="{Binding Name}" Style="{StaticResource BookmarkBarDisplayStyle}"
                                   Visibility="{Binding IsVisibility,Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Visible}}" />

                        <TextBlock Grid.Column="2" Text=">" Style="{StaticResource BookmarkBarIconStyle}"
                                   Visibility="{Binding IsShowSubIcon,Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Visible}}" />

                        <Popup Placement="{Binding PlacementMode}" AllowsTransparency="True" Focusable="False"
                               IsOpen="{Binding Path=IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border BorderThickness="1" BorderBrush="Black" SnapsToDevicePixels="True">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Grid" Property="Background" Value="{StaticResource ControlHoverBrush}"></Setter>
                        </Trigger>
                        <DataTrigger Binding="{Binding FirstLevel}" Value="False">
                            <Setter TargetName="TxtName" Property="MinWidth" Value="200"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                <Setter Property="ContextMenu" Value="{StaticResource FolderContextMenu}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsFolder}" Value="False">
                <Setter Property="ContextMenu" Value="{StaticResource BookmarkContextMenu}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--菜单样式-->
    <Style x:Key="BookmarkBarMenuStyle" TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
        <Setter Property="ItemTemplate" Value="{StaticResource BookmarkBarSubItemStyle}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource BookmarkBarMenuItemStyle}"/>
    </Style>
</ResourceDictionary>