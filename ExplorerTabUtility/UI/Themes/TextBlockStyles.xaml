<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Bookmark TextBlock Style-->
    <Style x:Key="BookmarkTextBlock" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="Margin" Value="4 0 0 10"/>
    </Style>

    <!-- Bookmark Title TextBlock Style-->
    <Style x:Key="BookmarkTitleTextBlock" TargetType="TextBlock" BasedOn="{StaticResource BookmarkTextBlock}">
        <Setter Property="FontSize" Value="18"/>
    </Style>
</ResourceDictionary>